{
  "name": "@goyal/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-dev-cache.mjs",
    "dev": "next dev --port 3000",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "start:standalone": "node scripts/start-standalone.mjs",
    "start:prod": "npm run build && npm run start:standalone",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.712.0",
    "@aws-sdk/s3-request-presigner": "^3.712.0",
    "@goyal/auth": "*",
    "@goyal/db": "*",
    "@goyal/email": "*",
    "@goyal/integrations": "*",
    "@goyal/types": "*",
    "@goyal/ui": "*",
    "@tailwindcss/postcss": "^4.0.0",
    "@tanstack/react-query": "^5.62.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "ioredis": "^5.11.1",
    "next": "^15.1.3",
    "next-auth": "^5.0.0-beta.25",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "vitest": "^2.1.8"
  }
}
