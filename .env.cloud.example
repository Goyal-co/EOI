# Cloud deployment (Render + Brevo + Upstash + Vercel Blob)
# Do NOT commit real secrets.

# ── App URLs (set to your Render web service URL) ───────────────────────────
NEXTAUTH_URL=https://goyal-eoi-web.onrender.com
NEXT_PUBLIC_APP_URL=https://goyal-eoi-web.onrender.com

# ── Database ────────────────────────────────────────────────────────────────
# Neon (Vercel): use POOLED URL for DATABASE_URL, DIRECT URL for DIRECT_URL
#   DATABASE_URL → host contains "-pooler" (app runtime)
#   DIRECT_URL   → host without "-pooler" (migrations only)
# Render/local: set DIRECT_URL same as DATABASE_URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth ────────────────────────────────────────────────────────────────────
AUTH_SECRET=generate-a-secure-random-string-at-least-32-chars
PII_ENCRYPTION_KEY=generate-a-32-byte-base64-key-for-pii

# Google OAuth — add redirect URI:
#   https://goyal-eoi-web.onrender.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Brevo) ─────────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxx
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=Goyal & Co. | Hariyana Group

# ── Redis (Upstash — free tier) ─────────────────────────────────────────────
# https://upstash.com → Create database → copy Redis URL (use TLS / rediss://)
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379

# ── File storage (Vercel Blob — free tier, works from Render) ───────────────
# 1. Create free account at https://vercel.com (no need to deploy the app there)
# 2. Storage → Blob → Create store → copy Read/Write token
# 3. Paste below — PDFs, brochures, KYC docs upload directly to Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# ── Cron (email retry queue) ────────────────────────────────────────────────
CRON_SECRET=generate-a-secure-random-string-for-cron-jobs

NODE_ENV=production

# ── Optional: AWS S3 instead of Vercel Blob (leave unset if using Blob) ─────
# S3_REGION=ap-south-1
# S3_BUCKET=goyal-eoi-documents
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
