# Production environment — copy to .env.production and fill in values
# For Vercel / Render cloud deploys, prefer .env.cloud.example (Neon, Upstash, S3/R2).

POSTGRES_USER=goyal
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=goyal_eoi

DATABASE_URL=postgresql://goyal:change-me-strong-password@postgres:5432/goyal_eoi?schema=public

AUTH_SECRET=generate-a-secure-random-string-at-least-32-chars
NEXTAUTH_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=goyal-eoi-documents
S3_ACCESS_KEY=change-me-minio-user
S3_SECRET_KEY=change-me-minio-password
S3_FORCE_PATH_STYLE=true

BREVO_API_KEY=xkeysib-xxxxxxxx
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=Goyal Projects

REDIS_URL=redis://redis:6379
CRON_SECRET=generate-a-secure-random-string-for-cron-jobs
PII_ENCRYPTION_KEY=generate-a-32-byte-base64-key-for-pii
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=GOYAL
MSG91_TEMPLATE_ID=

NODE_ENV=production
